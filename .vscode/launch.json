{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI",
      "type": "node-terminal",
      "request": "launch",
      "command": "& \"${workspaceFolder}\\backend\\.venv\\Scripts\\python.exe\" -m uvicorn app.main:app --reload --port 8080",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Frontend: Vite",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Agent: Collector",
      "type": "node-terminal",
      "request": "launch",
      "command": "$env:DASHBOARD_BASE_URL=\"http://localhost:8080\"; & \"${workspaceFolder}\\agent\\.venv\\Scripts\\python.exe\" pc_agent.py",
      "cwd": "${workspaceFolder}/agent"
    }
  ],
  "compounds": [
    {
      "name": "Sidecar Deck: All Components",
      "configurations": [
        "Backend: FastAPI",
        "Frontend: Vite",
        "Agent: Collector"
      ],
      "stopAll": true
    }
  ]
}

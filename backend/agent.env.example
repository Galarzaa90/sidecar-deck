# The base URL of the backend server collecting metrics
DASHBOARD_BASE_URL=http://homelab.local:8080
# An optional secret token to authenticate with the backend server
METRICS_TOKEN=change-me
# How often to push metrics
PUSH_INTERVAL_SECONDS=1
# The hostname to report to the backend server. If empty, the agent will attempt to determine the hostname automatically.
HOSTNAME=gaming-pc
# Log level for the agent
LOG_LEVEL=INFO
# Optional peripheral battery polling intervals
LOGITECH_BATTERY_POLL_SECONDS=30
BLUETOOTH_BATTERY_POLL_SECONDS=60
XINPUT_BATTERY_POLL_SECONDS=30
# Libre Hardware Monitor API configuration
LIBRE_HARDWARE_MONITOR_API_URL=http://127.0.0.1:8085/data.json
LIBRE_HARDWARE_MONITOR_TIMEOUT_SECONDS=0.75

# Configuration for diagnostic server
DIAGNOSTIC_HTTP_HOST=127.0.0.1
DIAGNOSTIC_HTTP_PORT=8765
